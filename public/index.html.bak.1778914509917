<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>JARVIS — AI Command Assistant</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Share+Tech+Mono&family=Exo+2:wght@300;400;600;800&display=swap');

  :root {
    --bg: #07090f;
    --panel: #0d1117;
    --border: #1a2a3a;
    --accent: #00e5ff;
    --accent2: #7b2fff;
    --green: #00ff88;
    --red: #ff3c5a;
    --text: #c9d8e8;
    --dim: #4a6070;
    --glow: 0 0 12px rgba(0,229,255,0.35);
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Exo 2', sans-serif;
    height: 100vh;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    position: relative;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background-image:
      linear-gradient(rgba(0,229,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,255,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none; z-index: 0;
  }

  body::after {
    content: '';
    position: fixed;
    width: 600px; height: 600px;
    background: radial-gradient(circle, rgba(123,47,255,0.08) 0%, transparent 70%);
    top: -200px; right: -100px;
    pointer-events: none; z-index: 0;
  }

  header {
    position: relative; z-index: 10;
    display: flex; align-items: center; justify-content: space-between;
    padding: 16px 28px;
    border-bottom: 1px solid var(--border);
    background: rgba(13,17,23,0.95);
    backdrop-filter: blur(10px);
  }

  .logo { display: flex; align-items: center; gap: 12px; }
  .logo-icon {
    width: 36px; height: 36px;
    border: 2px solid var(--accent);
    border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px;
    animation: pulse 3s ease-in-out infinite;
  }
  @keyframes pulse {
    0%,100% { box-shadow: 0 0 10px rgba(0,229,255,0.3); }
    50% { box-shadow: 0 0 22px rgba(0,229,255,0.7); }
  }
  .logo-text {
    font-size: 22px; font-weight: 800; letter-spacing: 4px;
    background: linear-gradient(90deg, var(--accent), var(--accent2));
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
  }
  .logo-sub { font-family: 'Share Tech Mono'; font-size: 10px; color: var(--dim); letter-spacing: 2px; }

  .status-bar { display: flex; align-items: center; gap: 18px; }
  .status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--green); box-shadow: 0 0 8px var(--green);
    animation: blink 2s step-start infinite;
  }
  @keyframes blink { 50% { opacity: 0.3; } }
  .status-label { font-family: 'Share Tech Mono'; font-size: 11px; color: var(--dim); letter-spacing: 1px; }

  .main-layout {
    position: relative; z-index: 5;
    display: flex; flex: 1;
    height: calc(100vh - 65px);
    overflow: hidden;
  }

  .sidebar {
    width: 220px; flex-shrink: 0;
    border-right: 1px solid var(--border);
    background: rgba(13,17,23,0.7);
    padding: 20px 16px;
    display: flex; flex-direction: column; gap: 6px;
    overflow-y: auto;
  }
  .sidebar-title {
    font-family: 'Share Tech Mono'; font-size: 10px;
    color: var(--dim); letter-spacing: 2px;
    margin-bottom: 10px; padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .mode-btn {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; border-radius: 8px;
    border: 1px solid transparent;
    background: transparent;
    color: var(--dim); font-family: 'Exo 2'; font-size: 13px;
    cursor: pointer; transition: all 0.2s; text-align: left;
  }
  .mode-btn:hover { background: rgba(0,229,255,0.06); color: var(--text); border-color: var(--border); }
  .mode-btn.active {
    background: rgba(0,229,255,0.1); border-color: var(--accent);
    color: var(--accent); box-shadow: inset 0 0 12px rgba(0,229,255,0.08);
  }
  .mode-icon { font-size: 16px; }
  .mode-sub { font-family: 'Share Tech Mono'; font-size: 9px; color: var(--dim); margin-top: 2px; }

  .chat-area { flex: 1; display: flex; flex-direction: column; overflow: hidden; }

  .messages {
    flex: 1; overflow-y: auto;
    padding: 24px 28px;
    display: flex; flex-direction: column; gap: 18px;
    scroll-behavior: smooth;
  }
  .messages::-webkit-scrollbar { width: 4px; }
  .messages::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }

  .welcome {
    text-align: center; padding: 50px 20px;
    display: flex; flex-direction: column; align-items: center; gap: 14px;
  }
  .welcome-icon { font-size: 52px; animation: float 4s ease-in-out infinite; }
  @keyframes float { 0%,100% { transform: translateY(0); } 50% { transform: translateY(-8px); } }
  .welcome h2 { font-size: 26px; font-weight: 800; letter-spacing: 2px; color: var(--accent); }
  .welcome p { color: var(--dim); font-size: 14px; max-width: 480px; line-height: 1.7; }
  .chips { display: flex; flex-wrap: wrap; justify-content: center; gap: 8px; margin-top: 8px; }
  .chip {
    padding: 7px 14px; border-radius: 20px;
    border: 1px solid var(--border); background: var(--panel);
    color: var(--dim); font-size: 12px; cursor: pointer;
    font-family: 'Share Tech Mono'; transition: all 0.2s;
  }
  .chip:hover { border-color: var(--accent); color: var(--accent); background: rgba(0,229,255,0.06); }

  .msg { display: flex; gap: 14px; animation: msgIn 0.3s ease; }
  @keyframes msgIn { from { opacity:0; transform: translateY(10px); } to { opacity:1; transform: translateY(0); } }
  .msg.user { flex-direction: row-reverse; }

  .avatar {
    width: 36px; height: 36px; border-radius: 8px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center; font-size: 16px;
  }
  .avatar.ai { background: linear-gradient(135deg, rgba(0,229,255,0.2), rgba(123,47,255,0.2)); border: 1px solid var(--accent); }
  .avatar.user { background: rgba(0,255,136,0.1); border: 1px solid rgba(0,255,136,0.4); }

  .bubble {
    max-width: 76%; padding: 14px 18px; border-radius: 12px;
    font-size: 14px; line-height: 1.7;
  }
  .bubble.ai { background: var(--panel); border: 1px solid var(--border); border-top-left-radius: 2px; color: var(--text); }
  .bubble.user { background: rgba(0,255,136,0.08); border: 1px solid rgba(0,255,136,0.25); border-top-right-radius: 2px; color: var(--green); text-align: right; }

  .bubble pre {
    margin-top: 10px;
    background: #050810;
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 14px;
    overflow-x: auto;
    font-family: 'Share Tech Mono'; font-size: 12px;
    color: var(--accent); line-height: 1.6;
  }
  .bubble code { font-family: 'Share Tech Mono'; color: var(--accent); font-size: 13px; }
  .code-header {
    display: flex; align-items: center; justify-content: space-between;
    margin-top: 10px; margin-bottom: -4px;
    font-family: 'Share Tech Mono'; font-size: 10px; color: var(--dim);
  }
  .copy-btn {
    padding: 3px 10px; border-radius: 4px;
    border: 1px solid var(--border); background: transparent;
    color: var(--dim); font-size: 10px; cursor: pointer; transition: all 0.2s;
  }
  .copy-btn:hover { border-color: var(--accent); color: var(--accent); }

  .typing { display: flex; gap: 5px; align-items: center; padding: 10px 0; }
  .typing span {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent); opacity: 0.4;
    animation: bounce 1.2s ease-in-out infinite;
  }
  .typing span:nth-child(2) { animation-delay: 0.2s; }
  .typing span:nth-child(3) { animation-delay: 0.4s; }
  @keyframes bounce { 0%,80%,100% { transform: scale(0.6); opacity:0.3; } 40% { transform: scale(1); opacity:1; } }

  .input-area {
    padding: 18px 28px 22px;
    border-top: 1px solid var(--border);
    background: rgba(13,17,23,0.95);
    backdrop-filter: blur(10px);
  }
  .input-wrapper {
    display: flex; align-items: flex-end; gap: 10px;
    background: var(--panel); border: 1px solid var(--border);
    border-radius: 14px; padding: 12px 14px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .input-wrapper:focus-within { border-color: var(--accent); box-shadow: 0 0 0 2px rgba(0,229,255,0.12); }
  textarea {
    flex: 1; background: transparent; border: none; outline: none;
    color: var(--text); font-family: 'Exo 2'; font-size: 14px;
    resize: none; line-height: 1.5; max-height: 140px; min-height: 22px;
  }
  textarea::placeholder { color: var(--dim); }
  .btn-group { display: flex; gap: 8px; align-items: flex-end; }

  .mic-btn, .send-btn, .speaker-btn {
    width: 40px; height: 40px; border-radius: 10px;
    border: none; cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    font-size: 18px; transition: all 0.2s; flex-shrink: 0;
  }
  .mic-btn { background: rgba(123,47,255,0.15); border: 1px solid rgba(123,47,255,0.4); }
  .mic-btn:hover { background: rgba(123,47,255,0.3); }
  .mic-btn.listening { background: rgba(255,60,90,0.2); border-color: var(--red); animation: pulse-red 1s infinite; }
  @keyframes pulse-red { 0%,100% { box-shadow: 0 0 0 0 rgba(255,60,90,0.4); } 50% { box-shadow: 0 0 0 8px rgba(255,60,90,0); } }

  .speaker-btn { background: rgba(0,229,255,0.15); border: 1px solid rgba(0,229,255,0.4); }
  .speaker-btn:hover { background: rgba(0,229,255,0.3); }
  .speaker-btn.active { background: rgba(0,229,255,0.3); border-color: var(--accent); animation: pulse 1s infinite; }
  .speaker-btn.muted { background: rgba(123,47,255,0.15); border-color: rgba(123,47,255,0.4); }

  .send-btn { background: linear-gradient(135deg, var(--accent), var(--accent2)); color: #000; font-weight: 700; }
  .send-btn:hover { opacity: 0.85; transform: scale(1.05); }
  .send-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; }

  .input-footer {
    display: flex; justify-content: space-between; align-items: center;
    margin-top: 8px;
    font-family: 'Share Tech Mono'; font-size: 10px; color: var(--dim);
  }
  .mode-indicator {
    padding: 3px 10px; border-radius: 12px;
    border: 1px solid var(--border); background: rgba(0,229,255,0.05);
    color: var(--accent); font-size: 10px;
  }
  .sidebar::-webkit-scrollbar { width: 3px; }
  .sidebar::-webkit-scrollbar-thumb { background: var(--border); }

  /* History items */
  .hist-item {
    font-family: 'Share Tech Mono'; font-size: 10px; color: var(--dim);
    overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    cursor: pointer; padding: 3px 0; line-height: 1.8;
  }
  .hist-item:hover { color: var(--accent); }

  /* Clear button */
  .clear-btn {
    margin-top: 10px;
    width: 100%; padding: 7px;
    border-radius: 6px; border: 1px solid var(--border);
    background: transparent; color: var(--dim);
    font-family: 'Share Tech Mono'; font-size: 10px;
    cursor: pointer; transition: all 0.2s;
  }
  .clear-btn:hover { border-color: var(--red); color: var(--red); }

  /* ─── NEW: User Profile & Settings ─── */
  .profile-btn {
    width: 36px; height: 36px; border-radius: 8px;
    background: rgba(0,229,255,0.1); border: 1px solid var(--border);
    color: var(--text); cursor: pointer; font-size: 16px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s;
  }
  .profile-btn:hover { background: rgba(0,229,255,0.2); border-color: var(--accent); }

  .profile-panel {
    position: fixed; top: 65px; right: 0; width: 320px; height: calc(100vh - 65px);
    background: rgba(13,17,23,0.98); border-left: 1px solid var(--border);
    padding: 20px; overflow-y: auto; display: none; z-index: 100;
    box-shadow: -8px 0 24px rgba(0,0,0,0.4);
  }
  .profile-panel.open { display: flex; flex-direction: column; }
  .profile-close { position: absolute; top: 10px; right: 10px; cursor: pointer; font-size: 20px; }
  .profile-title { font-size: 16px; font-weight: 700; margin-bottom: 16px; color: var(--accent); }
  .profile-item { margin-bottom: 14px; }
  .profile-label { font-family: 'Share Tech Mono'; font-size: 10px; color: var(--dim); text-transform: uppercase; margin-bottom: 4px; }
  .profile-input { width: 100%; padding: 8px 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--panel); color: var(--text); font-size: 12px; }
  .profile-stat { display: flex; justify-content: space-between; align-items: center; padding: 8px 10px; background: rgba(0,229,255,0.05); border-radius: 6px; margin-bottom: 6px; font-size: 11px; }
  .profile-stat-label { color: var(--dim); }
  .profile-stat-value { color: var(--accent); font-weight: 700; }

  /* ─── NEW: Sentiment & Feedback ─── */
  .msg-meta { display: flex; gap: 12px; margin-top: 8px; flex-wrap: wrap; }
  .sentiment-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 10px; border-radius: 12px; font-size: 10px;
    font-family: 'Share Tech Mono'; border: 1px solid var(--border);
  }
  .sentiment-positive { background: rgba(0,255,136,0.1); border-color: rgba(0,255,136,0.4); color: var(--green); }
  .sentiment-neutral { background: rgba(0,229,255,0.1); border-color: rgba(0,229,255,0.4); color: var(--accent); }
  .sentiment-negative { background: rgba(255,60,90,0.1); border-color: rgba(255,60,90,0.4); color: var(--red); }
  .sentiment-empathetic { background: rgba(123,47,255,0.1); border-color: rgba(123,47,255,0.4); color: #b88ff8; }

  .intent-tag { display: inline-block; padding: 3px 8px; border-radius: 10px; background: rgba(123,47,255,0.15); border: 1px solid rgba(123,47,255,0.4); color: #b88ff8; font-size: 9px; font-family: 'Share Tech Mono'; margin-right: 4px; }

  .feedback-group {
    display: flex; gap: 6px; align-items: center;
    margin-top: 6px;
  }
  .feedback-btn {
    width: 24px; height: 24px; border-radius: 4px;
    border: 1px solid var(--border); background: transparent;
    color: var(--dim); cursor: pointer; font-size: 12px;
    transition: all 0.2s; display: flex; align-items: center; justify-content: center;
  }
  .feedback-btn:hover { border-color: var(--accent); color: var(--accent); }
  .feedback-btn.active { background: rgba(0,229,255,0.2); border-color: var(--accent); color: var(--accent); }

  .entity-highlight {
    background: linear-gradient(120deg, rgba(0,229,255,0.2), rgba(123,47,255,0.2));
    border-radius: 3px; padding: 1px 3px;
    border-bottom: 1px dashed var(--accent);
  }

  .context-bar {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 12px; background: rgba(0,229,255,0.05);
    border-radius: 6px; margin-bottom: 12px;
    font-family: 'Share Tech Mono'; font-size: 9px; color: var(--dim);
  }
  .context-item { display: inline-flex; align-items: center; gap: 4px; }
  .context-dot { width: 4px; height: 4px; border-radius: 50%; background: var(--accent); }

  /* ─── Language & Storage ─── */
  .lang-selector {
    position: absolute; top: 12px; left: 320px;
    display: flex; align-items: center; gap: 6px;
    z-index: 15;
  }
  .lang-btn {
    padding: 6px 10px; border-radius: 6px; border: 1px solid var(--border);
    background: rgba(0,229,255,0.05); color: var(--text); font-size: 10px;
    cursor: pointer; transition: all 0.2s; font-family: 'Share Tech Mono';
  }
  .lang-btn:hover { border-color: var(--accent); color: var(--accent); }
  .lang-btn.active { background: rgba(0,229,255,0.2); border-color: var(--accent); color: var(--accent); }

  .storage-badge {
    display: inline-flex; align-items: center; gap: 4px;
    padding: 4px 8px; border-radius: 6px; background: rgba(0,255,136,0.1);
    border: 1px solid rgba(0,255,136,0.3); color: var(--green);
    font-family: 'Share Tech Mono'; font-size: 9px;
  }

  .conversation-history-modal {
    position: fixed; top: 65px; left: 220px; width: 400px; max-height: 600px;
    background: rgba(13,17,23,0.98); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px; overflow-y: auto;
    display: none; z-index: 100; box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .conversation-history-modal.open { display: flex; flex-direction: column; }
  .conv-item {
    padding: 10px; margin-bottom: 8px; border-radius: 6px;
    background: rgba(0,229,255,0.08); border: 1px solid var(--border);
    cursor: pointer; font-size: 11px; transition: all 0.2s;
  }
  .conv-item:hover { background: rgba(0,229,255,0.15); border-color: var(--accent); }
  .conv-item.active { background: rgba(0,229,255,0.2); border-color: var(--accent); }
  .conv-time { font-family: 'Share Tech Mono'; color: var(--dim); font-size: 9px; }
  .conv-preview { color: var(--text); margin-top: 4px; }

  .storage-controls {
    display: flex; gap: 6px; margin-bottom: 12px;
  }
  .storage-btn {
    flex: 1; padding: 6px; border-radius: 6px; border: 1px solid var(--border);
    background: rgba(123,47,255,0.1); color: #b88ff8; font-size: 10px;
    cursor: pointer; font-family: 'Share Tech Mono'; transition: all 0.2s;
  }
  .storage-btn:hover { background: rgba(123,47,255,0.2); border-color: #b88ff8; }

  /* ─── Feature Development System ─── */
  .feature-request-modal {
    position: fixed; top: 65px; right: 0; width: 500px; max-height: 80vh;
    background: rgba(13,17,23,0.99); border-left: 1px solid var(--border);
    padding: 20px; overflow-y: auto; display: none; z-index: 100;
    box-shadow: -12px 0 32px rgba(0,0,0,0.5);
  }
  .feature-request-modal.open { display: flex; flex-direction: column; }
  .feature-close { position: absolute; top: 10px; right: 10px; cursor: pointer; font-size: 20px; color: var(--red); }

  .feature-title { font-size: 14px; font-weight: 700; color: var(--accent); margin-bottom: 12px; }
  .feature-input { width: 100%; padding: 10px; border-radius: 6px; border: 1px solid var(--border); background: var(--panel); color: var(--text); font-size: 12px; font-family: 'Exo 2'; min-height: 60px; resize: vertical; }

  .feature-code-display {
    background: rgba(0,0,0,0.3); border: 1px solid var(--border); border-radius: 8px;
    padding: 12px; margin: 12px 0; max-height: 400px; overflow-y: auto;
    font-family: 'Share Tech Mono'; font-size: 11px; color: var(--accent);
    line-height: 1.5;
  }

  .feature-buttons { display: flex; gap: 8px; margin-bottom: 12px; }
  .feature-btn {
    flex: 1; padding: 8px; border-radius: 6px; border: 1px solid var(--border);
    background: rgba(0,229,255,0.1); color: var(--accent); font-size: 11px;
    cursor: pointer; font-family: 'Share Tech Mono'; transition: all 0.2s;
  }
  .feature-btn:hover { background: rgba(0,229,255,0.2); border-color: var(--accent); }
  .feature-btn.success { background: rgba(0,255,136,0.1); border-color: var(--green); color: var(--green); }
  .feature-btn.danger { background: rgba(255,60,90,0.1); border-color: var(--red); color: var(--red); }

  .feature-status {
    padding: 10px; border-radius: 6px; border-left: 3px solid var(--accent);
    background: rgba(0,229,255,0.08); color: var(--text); font-size: 11px;
    margin-bottom: 12px;
  }

  .feature-registry {
    background: rgba(0,229,255,0.05); border: 1px solid var(--border); border-radius: 6px;
    padding: 12px; margin-top: 12px;
  }

  .feature-item {
    padding: 8px; background: rgba(0,229,255,0.08); border-radius: 4px;
    margin-bottom: 6px; font-size: 10px; border-left: 2px solid var(--green);
  }

  .dev-btn {
    width: 40px; height: 40px; border-radius: 10px;
    border: 1px solid rgba(123,47,255,0.4); background: rgba(123,47,255,0.15);
    color: #b88ff8; cursor: pointer; font-size: 18px;
    display: flex; align-items: center; justify-content: center;
    transition: all 0.2s; flex-shrink: 0;
  }
  .dev-btn:hover { background: rgba(123,47,255,0.3); }

  /* ─── Feature Builder & Search ─── */
  .feature-builder-modal {
    position: fixed; top: 65px; left: 220px; width: 450px; max-height: 700px;
    background: rgba(13,17,23,0.98); border: 1px solid var(--border);
    border-radius: 8px; padding: 16px; overflow-y: auto;
    display: none; z-index: 100; box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  }
  .feature-builder-modal.open { display: flex; flex-direction: column; }
  
  .feature-request-input {
    width: 100%; padding: 10px; border-radius: 6px;
    border: 1px solid var(--border); background: var(--panel);
    color: var(--text); font-family: 'Exo 2'; font-size: 12px;
    margin-bottom: 10px; resize: vertical; min-height: 60px;
  }
  
  .dev-button {
    width: 100%; padding: 8px; border-radius: 6px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    color: #000; border: none; cursor: pointer; font-weight: 700;
    font-family: 'Exo 2'; margin-bottom: 8px; transition: all 0.2s;
  }
  .dev-button:hover { opacity: 0.85; transform: scale(1.02); }
  .dev-button:disabled { opacity: 0.4; cursor: not-allowed; }

  .search-result {
    padding: 12px; margin-bottom: 10px; border-radius: 6px;
    background: rgba(0,229,255,0.08); border: 1px solid var(--border);
    font-size: 11px; line-height: 1.6;
  }
