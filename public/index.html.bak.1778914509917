  learningDatabase.successfulImplementations++;
  learningDatabase.developmentHistory.push({
    timestamp: new Date().toLocaleString(),
    feature: feature.description,
    type: feature.type,
    implementation: feature.implementation.substring(0, 200)
  });
  
  // Track user development preferences
  if (!learningDatabase.userPreferences[feature.type]) {
    learningDatabase.userPreferences[feature.type] = 0;
  }
  learningDatabase.userPreferences[feature.type]++;
  
  saveFeatureData();
  
  // Send tracking to server
  fetch('/api/features/track', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      feature: feature.description,
      type: feature.type,
      status: 'implemented',
      userProfile: userProfile
    })
  }).catch(err => console.log('📌 Server tracking note:', err.message));
  
  // Update user profile stats
  if (!userProfile.stats.features) {
    userProfile.stats.features = { implemented: 0, requested: 0 };
  }
  userProfile.stats.features.implemented++;
  saveProfile();
  
  alert(`✅ FEATURE IMPLEMENTATION STARTED!

📌 JARVIS is now working on:
"${feature.description}"

JARVIS has learned:
✓ How to create ${feature.type} features
✓ You prefer this development pattern
✓ Success rate improved to ${Math.round(learningDatabase.successfulImplementations / learningDatabase.requestCount * 100)}%

🧠 JARVIS will use this knowledge to:
- Suggest similar features faster
- Auto-complete implementation steps
- Recommend related features
- Personalize future development suggestions

💡 Check the 🧠 JARVIS LEARNING panel to see insights!`);
  
  document.getElementById('featureDesc').value = '';
  displayFeaturesList();
}

function declineFeature(featureId) {
  featureRequests = featureRequests.filter(f => f.id !== featureId);
  saveFeatureData();
  displayFeaturesList();
  alert('Feature declined.');
}

function displayFeaturesList() {
  const container = document.getElementById('featuresList');
  
  if (implementedFeatures.length === 0 && featureRequests.length === 0) {
    container.innerHTML = `<div style="color:var(--dim);font-size:11px;text-align:center;padding:12px;">
      No features requested yet. 🚀 Request a feature to get started!
    </div>`;
    return;
  }
  
  let html = '<div style="margin-top:12px;"><div class="dev-label">📦 FEATURE ROADMAP</div>';
  
  if (implementedFeatures.length > 0) {
    html += '<div style="margin-bottom:12px;"><div style="font-size:10px;color:var(--accent);margin-bottom:6px;">✓ IMPLEMENTED:</div>';
    implementedFeatures.slice(-3).forEach(f => {
      html += `<div class="feature-card">
        <div>${f.description}</div>
        <div style="margin-top:6px;font-size:9px;">
          <span class="feature-status implemented">✓ Implemented</span>
          <span style="color:var(--dim);margin-left:8px;">${f.timestamp}</span>
        </div>
      </div>`;
    });
    html += '</div>';
  }
  
  if (featureRequests.length > 0) {
    html += '<div><div style="font-size:10px;color:#b88ff8;margin-bottom:6px;">⏳ PENDING:</div>';
    featureRequests.forEach(f => {
      html += `<div class="feature-card">
        <div>${f.description}</div>
        <div style="margin-top:6px;font-size:9px;">
          <span class="feature-status pending">⏳ Pending</span>
          <span style="color:var(--dim);margin-left:8px;">${f.type}</span>
        </div>
      </div>`;
    });
    html += '</div>';
  }
  
  // Learning insights
  html += `<div class="learning-insights">
    <div style="font-weight:700;color:var(--accent);margin-bottom:8px;">🧠 JARVIS LEARNING</div>
    <div class="learning-item"><span class="learning-icon">📊</span> Features Requested: ${learningDatabase.requestCount}</div>
    <div class="learning-item"><span class="learning-icon">✓</span> Implementations: ${learningDatabase.successfulImplementations}</div>
    <div class="learning-item"><span class="learning-icon">📚</span> Development Patterns: ${learningDatabase.developmentHistory.length}</div>
    <div class="learning-item"><span class="learning-icon">🎯</span> Success Rate: ${learningDatabase.requestCount > 0 ? Math.round(learningDatabase.successfulImplementations / learningDatabase.requestCount * 100) : 0}%</div>
  </div>`;
  
  html += '</div>';
  container.innerHTML = html;
}

// ═════════════════════════════════════════════════════════
// DYNAMIC FEATURE DEVELOPMENT & LEARNING SYSTEM
// ═════════════════════════════════════════════════════════

let trainingData = {
  features: [],
  searches: [],
  patterns: [],
  learned: false
};

let developedFeatures = [];

function toggleDevModal() {
  const modal = document.getElementById('devModal');
  if (!modal) return;
  modal.classList.toggle('open');
  if (modal.classList.contains('open')) {
    document.getElementById('devResponse').style.display = 'none';
    displayFeaturesList();
  }
}

function selectFeatureType(btn) {
  document.querySelectorAll('.ftype-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  document.getElementById('featureType').value = btn.dataset.value;
}

function createDevModal() {
  const modal = document.createElement('div');
  modal.id = 'devModal';
  modal.className = 'feature-builder-modal';
  modal.innerHTML = `
    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
      <h3 style="color:var(--accent); margin:0;">🚀 FEATURE DEVELOPMENT & LEARNING</h3>
      <button onclick="toggleDevModal()" style="background:none; border:none; color:var(--text); cursor:pointer; font-size:18px;">✕</button>
    </div>
    
    <div style="margin-bottom:12px;">
      <label style="color:var(--dim); font-family:'Share Tech Mono'; font-size:10px;">📋 WHAT DO YOU NEED?</label>
      <textarea id="featureDesc" class="feature-request-input" placeholder="Example: Add a search feature for temples, Create a calculator, Add note-taking feature..."></textarea>
    </div>
    
    <button class="dev-button" onclick="submitFeatureRequest()">⚡ GENERATE FEATURE</button>
    <button class="dev-button" onclick="performSearch()" style="background:rgba(0,229,255,0.2);">🔍 SEARCH & LEARN</button>
    
    <div id="devResponse" style="margin-top:12px;"></div>
    <div id="knowledgeBase" style="margin-top:12px; max-height:200px; overflow-y:auto;"></div>
  `;
  document.body.appendChild(modal);
  modal.classList.add('open');
}

function displayLearningKnowledge() {
  const kb = document.getElementById('knowledgeBase');
  if (!kb) return;
  
  const modal = document.getElementById('devModal');
  if (!modal) return;
  
  let html = '<div style="border-top:1px solid var(--border); padding-top:12px;"><h4 style="color:#b88ff8; font-size:10px; margin-bottom:8px;">📚 TRAINING & LEARNED PATTERNS:</h4>';
  
  if (trainingData.features.length > 0) {
    html += `<div class="knowledge-item"><span class="knowledge-label">Features Developed:</span> ${trainingData.features.length}</div>`;
  }
  
  if (trainingData.searches.length > 0) {
    html += `<div class="knowledge-item"><span class="knowledge-label">Searches Performed:</span> ${trainingData.searches.length}</div>`;
    trainingData.searches.slice(-3).forEach(search => {
      html += `<div class="knowledge-item" style="margin-left:8px;">🔍 ${search}</div>`;
    });
  }
  
  if (trainingData.patterns.length > 0) {
    html += `<div class="knowledge-item"><span class="knowledge-label">Learned Patterns:</span> ${trainingData.patterns.length}</div>`;
  }
  
  html += '</div>';
  kb.innerHTML = html;
}

async function submitFeatureRequest() {
  const desc = document.getElementById('featureDesc')?.value;
  if (!desc) {
    alert('Please describe what feature you need');
    return;
  }
  
  const response = document.getElementById('devResponse');
  response.style.display = 'block';
  response.innerHTML = '<div class="feature-status status-building">⚙️ JARVIS is analyzing your request and generating code...</div>';
  
  try {
    // Send request to server for feature generation
    const result = await fetch('/api/develop-feature', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        description: desc,
        userProfile,
        currentMode,
        language: currentLanguage
      })
    });
    
    const data = await result.json();
    
    // Train on this feature request
    trainingData.features.push(desc);
    trainingData.patterns.push({
      request: desc,
      type: data.type || 'custom',
      timestamp: new Date()
    });
    localStorage.setItem('jarvisTrainingData', JSON.stringify(trainingData));
    
    if (data.success) {
      // Store generated data so the apply button can access it
      window._pendingFeature = data;

      response.innerHTML = `
        <div class="feature-status status-complete" style="padding:10px;">
          ✅ <strong>${data.featureName}</strong> — code generated!<br>
          <small style="color:var(--dim);">${data.description}</small>
          <div style="margin-top:10px; display:flex; gap:8px; flex-wrap:wrap;">
            <button class="dev-btn-submit" onclick="applyFeatureToLocalFiles()">
              🔧 APPLY TO LOCAL FILES
            </button>
            <button class="dev-button" onclick="window._pendingFeature=null;document.getElementById('devResponse').innerHTML='';" style="font-size:11px;">
              ✗ DISCARD
            </button>
          </div>
        </div>
      `;

      // Also show code in chat
      developedFeatures.push(data);
      addMessage('ai', `✅ **Feature Developed!**\n**${data.featureName}**\n${data.description}\n\n**Code Generated:**\n\`\`\`${data.language || 'javascript'}\n${data.code}\n\`\`\`\n\nClick **🔧 APPLY TO LOCAL FILES** in the dev panel to write this to the project.`);

    } else {
      response.innerHTML = `<div class="feature-status status-error">❌ ${data.error || 'Feature generation failed'}</div>`;
    }
  } catch(err) {
    response.innerHTML = `<div class="feature-status status-error">❌ Error: ${err.message}</div>`;
  }
}

async function applyFeatureToLocalFiles() {
  const feat = window._pendingFeature;
  if (!feat) { alert('No pending feature to apply.'); return; }

  const resp = document.getElementById('devResponse');
  resp.innerHTML = `<div class="feature-status status-building">🔧 Writing "${feat.featureName}" to local files...</div>`;

  try {
    const result = await fetch('/api/apply-feature', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        code: feat.code,
        type: feat.type,
        featureName: feat.featureName
      })
    });

    const out = await result.json();

    if (out.success) {
      resp.innerHTML = `
        <div class="feature-status status-complete" style="padding:10px;">
          ✅ <strong>${feat.featureName}</strong> applied to <code>${out.file}</code>!<br>
          <small style="color:var(--dim);">${out.message}</small>
          ${out.requiresReload   ? `<br><button class="dev-btn-submit" style="margin-top:8px;" onclick="location.reload()">🔄 RELOAD PAGE</button>` : ''}
          ${out.requiresRestart  ? `<br><small style="color:#f90;">⚠️ Restart the server (Ctrl+C → node server.js) to activate backend changes.</small>` : ''}
        </div>
      `;
      window._pendingFeature = null;

      // Track in learning database
      trainingData.features.push(feat.featureName);
      localStorage.setItem('jarvisTrainingData', JSON.stringify(trainingData));

    } else {
      resp.innerHTML = `<div class="feature-status status-error">❌ Apply failed: ${out.error}</div>`;
    }
  } catch(err) {
    resp.innerHTML = `<div class="feature-status status-error">❌ Error: ${err.message}</div>`;
  }
}

async function performSearch() {
  const query = document.getElementById('featureDesc')?.value;
  if (!query) {
    alert('Please enter a search term');
    return;
  }
  
  const response = document.getElementById('devResponse');
  response.innerHTML = '<div class="feature-status status-building">🔍 JARVIS is searching and learning...</div>';
  
  try {
    const result = await fetch('/api/search', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        query: query,
        language: currentLanguage
      })
    });
    
    const data = await result.json();
    
    // Record search in training data
    trainingData.searches.push(query);
    localStorage.setItem('jarvisTrainingData', JSON.stringify(trainingData));
    
    if (data.results && data.results.length > 0) {
      let html = '<div style="border-top:1px solid var(--border); padding-top:12px;">';
      data.results.slice(0, 3).forEach((result, idx) => {
        html += `
          <div class="search-result">
            <div class="search-result-title">${idx + 1}. ${result.title}</div>
            <div class="search-result-snippet">${result.snippet}</div>
            <div class="search-result-url">🔗 ${result.url}</div>
          </div>
        `;
      });
      html += '</div>';
      response.innerHTML = html;
      
      // Add to chat
      addMessage('ai', `📚 **Search Results for "${query}":**\n\n${data.results.slice(0, 3).map((r, i) => `${i + 1}. **${r.title}**\n   ${r.snippet}\n   🔗 ${r.url}`).join('\n\n')}`);
    } else {
      response.innerHTML = '<div class="feature-status status-error">❌ No results found</div>';
    }
  } catch(err) {
    response.innerHTML = `<div class="feature-status status-error">❌ Search Error: ${err.message}</div>`;
  }
}

function loadTrainingData() {
  const saved = localStorage.getItem('jarvisTrainingData');
  if (saved) {
    trainingData = JSON.parse(saved);
    console.log('📚 Training data loaded:', trainingData);
  }
}

function showDevelopedFeatures() {
  let html = '<div style="margin-top:16px; border-top:1px solid var(--border); padding-top:12px;">';
  html += '<h4 style="color:var(--accent); font-size:11px; margin-bottom:8px;">🎉 RECENTLY DEVELOPED FEATURES:</h4>';
  
  if (developedFeatures.length === 0) {
    html += '<span style="color:var(--dim); font-size:10px;">No features developed yet</span>';
  } else {
    developedFeatures.slice(-5).forEach(feat => {
      html += `
        <div style="padding:8px; margin-bottom:6px; border-radius:4px; background:rgba(0,255,136,0.08); border-left:2px solid var(--green);">
          <div style="color:var(--green); font-weight:700; font-size:10px;">✅ ${feat.featureName}</div>
          <div style="color:var(--text); font-size:9px;">${feat.description}</div>
        </div>
      `;
    });
  }
  
  html += '</div>';
  return html;
}

// Load training data on startup
loadTrainingData();


// ── Initialize Voices ──
function initializeVoices() {
  const voices = window.speechSynthesis.getVoices();
  const langMap = {
    'ta': 'Tamil',
    'hi': 'Hindi',
    'en': 'English',
    'es': 'Spanish',
    'fr': 'French'
  };
  
  console.log('🎙️ Available Voices:');
  for (const [lang, name] of Object.entries(langMap)) {
    const available = voices.filter(v => v.lang.startsWith(lang)).length > 0;
    const status = available ? '✓' : '✗';
    console.log(`${status} ${name} (${lang})`);
  }
  console.log('🔊 Full voices list:', voices.map(v => `${v.name} (${v.lang})`).join(', '));
}

// Initialize voices when available
if (window.speechSynthesis.onvoiceschanged !== undefined) {
  window.speechSynthesis.onvoiceschanged = initializeVoices;
}

// Also call on load
window.addEventListener('load', () => {
  setTimeout(initializeVoices, 500);
});
</script>
