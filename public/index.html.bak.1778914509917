    if (sentiment) {
      metaHTML += `<span class="sentiment-badge sentiment-${sentiment.type}">${sentiment.emoji} ${sentiment.label}</span>`;
    }
    if (intent && intent.length > 0) {
      intent.forEach(i => metaHTML += `<span class="intent-tag">🎯 ${i.toUpperCase()}</span>`);
    }
    metaHTML += `<div class="feedback-group">
      <button class="feedback-btn" onclick="rateFeedback(this, 1)" title="Helpful">👍</button>
      <button class="feedback-btn" onclick="rateFeedback(this, 0)" title="Not Helpful">👎</button>
      <button class="feedback-btn" onclick="rateFeedback(this, 0.5)" title="Partial">⚬</button>
    </div></div>`;
  }

  let contentHTML = parseContent(text);
  if (entities && entities.length > 0) {
    entities.forEach(e => {
      const regex = new RegExp(`\\b${e.text}\\b`, 'gi');
      contentHTML = contentHTML.replace(regex, `<span class="entity-highlight" title="${e.type}">${e.text}</span>`);
    });
  }

  div.innerHTML = `
    <div class="avatar ${role}">${isAI ? '⬡' : '▶'}</div>
    <div class="bubble ${role}">
      ${contentHTML}
      ${metaHTML}
