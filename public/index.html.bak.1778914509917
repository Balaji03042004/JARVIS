// ── API Call — hits LOCAL server ──
async function callJarvis(userMessage) {
  conversationHistory.push({ role: 'user', content: userMessage });

  // Calls your local Node.js server — NO CORS issue!
  const response = await fetch('/api/chat', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({
      model: 'claude-sonnet-4-20250514',
      max_tokens: 1000,
      system: SYSTEM_PROMPTS[currentMode],
      messages: conversationHistory,
      userProfile: userProfile,  // Send profile to server for personalization
      language: currentLanguage   // Send language preference
    })
  });

  if (!response.ok) {
    const err = await response.json();
    throw new Error(err.error || `Server error ${response.status}`);
  }

  const data = await response.json();
  const reply = data.content.map(b => b.text || '').join('');
  conversationHistory.push({ role: 'assistant', content: reply });
  return reply;
}

// ── Send ──
async function sendMessage() {
  const input = document.getElementById('userInput');
  const text = input.value.trim();
  if (!text || isLoading) return;
  isLoading = true;
  document.getElementById('sendBtn').disabled = true;
  input.value = ''; input.style.height = 'auto';

  // Analyze user message
  const userSentiment = analyzeSentiment(text);
  const userIntent = detectIntent(text);
  const entities = extractEntities(text);

  // Track stats
  userProfile.stats.messages++;
  userProfile.stats.sentiment.push(userSentiment.type === 'positive' ? 1 : userSentiment.type === 'negative' ? -1 : 0);
  userIntent.forEach(i => userProfile.stats.topics.push(i));

  // Display user message with analysis
  addMessage('user', text);
  addTypingIndicator();
  setStatus('🧠 ANALYZING & RESPONDING...');

  try {
    const reply = await callJarvis(text);
    removeTypingIndicator();

    // Analyze AI response
    const aiSentiment = analyzeSentiment(reply);
    const aiIntent = detectIntent(reply);
    const replyEntities = extractEntities(reply);

    // Display with full analysis
    addEnhancedMessage('ai', reply, aiSentiment, aiIntent, replyEntities);

    // Update learning profile & auto-save
    saveProfile();
    updateContextBar();
    autoSaveConversation();
    setStatus('✓ SYSTEM ONLINE');
  } catch(err) {
    removeTypingIndicator();
    addMessage('ai', `⚠️ **Error**: ${err.message}\n\nMake sure your server is running: **node server.js**`);
    setStatus('ERROR', true);
  }

  isLoading = false;
  document.getElementById('sendBtn').disabled = false;
  input.focus();
}

